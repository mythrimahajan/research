def phi_time(t, y_flat):
    dt = t - last_t[0]
    if dt > 0:
        pbar.update(dt)
    last_t[0] = t
    #reshape flattened arrays from solve_ivp
    phi1 = y_flat[0]
    phi2 = y_flat[1]
    theta1 = y_flat[2:2+N*N].reshape(N,N)
    theta2 = y_flat[2+N*N:2+2*N*N].reshape(N,N)
    I = intensity(t)
    theta = theta2 - theta1
    
    # vectorized laplacians
    lap_theta1 = (np.roll(theta1,-1,axis=0) + np.roll(theta1,1,axis=0) +
                  np.roll(theta1,-1,axis=1) + np.roll(theta1,1,axis=1) - 4*theta1) / dx**2
    lap_theta2 = (np.roll(theta2,-1,axis=0) + np.roll(theta2,1,axis=0) +
                  np.roll(theta2,-1,axis=1) + np.roll(theta2,1,axis=1) - 4*theta2) / dx**2
    
    theta1_gradient = np.gradient(theta1, dx) 
    theta2_gradient = np.gradient(theta2, dx)
    theta1_grad_sq = theta1_gradient[0]**2 + theta1_gradient[1]**2 # (∂μθ1)²
    theta2_grad_sq = theta2_gradient[0]**2 + theta2_gradient[1]**2 # (∂μθ2)²

    
    #calculating the Aμ∂μθi
    A = np.sqrt(I) 
    A_d_mu_theta1 = np.mean(A * (theta1_gradient[0] + theta1_gradient[1]))
    A_d_mu_theta2 = np.mean(A * (theta2_gradient[0] + theta2_gradient[1]))

    #take mean of below terms so that phi1 and phi2 can be spatially uniform 
    phi1_term = np.mean(theta1_grad_sq - 4*A_d_mu_theta1 + 4*I)
    phi2_term = np.mean(theta2_grad_sq - 4*A_d_mu_theta2 + 4*I)
    
    dphi1_dt = -gamma1 * ((0.5*alpha1*phi1) + 0.5*b1*phi1*phi1_term + (2*u1*phi1**3) + (gamma3*phi2*np.mean(np.cos(theta))))     
    dphi2_dt = -gamma2 * ((0.5*alpha2*phi2) + 0.5*b2*phi2*phi2_term + (2*u2*phi2**3) + (gamma3*phi1*np.mean(np.cos(theta)))) 
    
    
    dtheta1_dt = -gamma1 * (-0.5*b1*(lap_theta1)*phi1 + gamma3*phi2*np.sin(theta)) #+ noise_theta1
    dtheta2_dt = -gamma2 * (-0.5*b2*(lap_theta2)*phi2 + gamma3*phi1*np.sin(theta)) #+ noise_theta2
    
    derivatives_flat = np.concatenate([[dphi1_dt, dphi2_dt], dtheta1_dt.flatten(), dtheta2_dt.flatten()])
    
    return derivatives_flat


