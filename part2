#free energy, equation V.4 integrated  
def free_energy(phi1, phi2, eq_v3):
    f = 0.25*alpha1*phi1**2 + 0.25*alpha2*phi2**2 + 0.5*u1*phi1**4 + 0.5*u2*phi2**4 + gamma3*phi1*phi2*np.cos(eq_v3)
    return f


def zeta(t):
    sigma = k_0 * c_light * tao
    p1 = np.sqrt(2 * np.pi) * (1 + (1/sigma**2)) 
    p2 = erf(np.sqrt(2) * (t/tao))
    p3 = 4 * (1/sigma**2) * (t/tao) * np.exp(-2 * ((t/tao)**2))
    zeta = (p1  * p2) - p3 
    return zeta 


def intensity(t):
    p1 = 1 + (4 * (t / (k_0 * c_light * tao**2))**2)
    p2 = np.exp(-2 * ((t / tao)**2))
    I = I_0 * p1 * p2
    return I


